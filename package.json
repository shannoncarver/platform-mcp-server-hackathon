{
  "name": "platform-mcp-server-hackathon",
  "version": "0.1.0",
  "private": true,
  "description": "LINQ Platform MCP Server — V1 internal-only design (AWS SSO + SigV4 + federated API Gateway dispatch).",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "bin": {
    "platform-mcp-shim": "bin/platform-mcp-shim.js"
  },
  "files": [
    "bin/",
    "scripts/platform-mcp-shim.ts",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:shim": "esbuild scripts/platform-mcp-shim.ts --bundle --platform=node --target=node20 --format=cjs --outfile=bin/platform-mcp-shim.js && chmod +x bin/platform-mcp-shim.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/credential-provider-node": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@smithy/protocol-http": "^4.1.0",
    "@smithy/signature-v4": "^4.2.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
